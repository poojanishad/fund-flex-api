{
  "info": {
    "name": "Fund Transfer API",
    "description": "Complete test collection for the Fund Transfer API.\n\n## Setup\n1. Import this collection into Postman\n2. Import `Fund-Transfer-API.postman_environment.json` as the environment\n3. Select the **Fund Transfer API - Local** environment\n4. Run requests in order — Idempotency group reuses referenceId from step above\n\n## Tips\n- Run the full collection via Collection Runner for automated testing\n- Each request has Tests tab assertions\n- $guid generates a unique UUID per request automatically",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",       "value": "http://localhost:8000" },
    { "key": "account1Id",    "value": "1" },
    { "key": "account2Id",    "value": "2" },
    { "key": "account3Id",    "value": "3" },
    { "key": "idemResponse1", "value": "" }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('Status is 200 or 503', () => pm.expect(pm.response.code).to.be.oneOf([200, 503]));",
              "pm.test('Has status field', () => pm.expect(pm.response.json()).to.have.property('status'));",
              "pm.test('Has database field', () => pm.expect(pm.response.json()).to.have.property('database'));",
              "pm.test('Has redis field', () => pm.expect(pm.response.json()).to.have.property('redis'));",
              "pm.test('Database is UP', () => pm.expect(pm.response.json().database).to.eql('UP'));",
              "pm.test('status is OK or DEGRADED', () => pm.expect(['OK','DEGRADED']).to.include(pm.response.json().status));"
            ]}
          }]
        }
      ]
    },
    {
      "name": "Happy Path",
      "item": [
        {
          "name": "POST /api/transfer — success",
          "event": [
            {
              "listen": "prerequest",
              "script": { "type": "text/javascript", "exec": [
                "const ref = 'ref-happy-' + Date.now();",
                "pm.collectionVariables.set('happyRef', ref);",
                "const body = JSON.parse(pm.request.body.raw);",
                "body.referenceId = ref;",
                "pm.request.body.raw = JSON.stringify(body, null, 4);"
              ]}
            },
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('success = true', () => pm.expect(pm.response.json().success).to.be.true);",
                "pm.test('status = SUCCESS', () => pm.expect(pm.response.json().data.status).to.eql('SUCCESS'));",
                "pm.test('referenceId present', () => pm.expect(pm.response.json().data).to.have.property('referenceId'));",
                "pm.test('Response under 2s', () => pm.expect(pm.response.responseTime).to.be.below(2000));"
              ]}
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type",    "value": "application/json"},
              {"key": "Idempotency-Key", "value": "{{$guid}}"}
            ],
            "body": { "mode": "raw", "raw": "{\n    \"fromAccount\": {{account1Id}},\n    \"toAccount\":   {{account2Id}},\n    \"amount\":      \"100.00\",\n    \"referenceId\": \"placeholder\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/transfer", "host": ["{{baseUrl}}"], "path": ["api","transfer"] }
          }
        },
        {
          "name": "POST /api/transfer — exact full balance",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 200 — full balance transfer allowed', () => pm.response.to.have.status(200));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{$guid}}"}],
            "body": { "mode": "raw", "raw": "{\n    \"fromAccount\": {{account1Id}},\n    \"toAccount\":   {{account2Id}},\n    \"amount\":      \"50.00\",\n    \"referenceId\": \"full-bal-{{$timestamp}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/transfer", "host": ["{{baseUrl}}"], "path": ["api","transfer"] }
          }
        },
        {
          "name": "POST /api/transfer — small decimal 0.01",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 200 — 0.01 transfer works', () => pm.response.to.have.status(200));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{$guid}}"}],
            "body": { "mode": "raw", "raw": "{\n    \"fromAccount\": {{account1Id}},\n    \"toAccount\":   {{account2Id}},\n    \"amount\":      \"0.01\",\n    \"referenceId\": \"small-{{$timestamp}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/transfer", "host": ["{{baseUrl}}"], "path": ["api","transfer"] }
          }
        }
      ]
    },
    {
      "name": "Idempotency",
      "item": [
        {
          "name": "POST — 1st request (sets idem key)",
          "event": [
            {"listen": "prerequest", "script": {"type": "text/javascript", "exec": [
              "pm.collectionVariables.set('fixedIdemKey', 'fixed-key-' + Math.floor(Date.now()/10000));"
            ]}},
            {"listen": "test", "script": {"type": "text/javascript", "exec": [
              "pm.test('Status 200', () => pm.response.to.have.status(200));",
              "pm.collectionVariables.set('idemResponse1', pm.response.text());",
              "console.log('Saved first response for comparison');"
            ]}}
          ],
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{fixedIdemKey}}"}],
            "body": { "mode": "raw", "raw": "{\n    \"fromAccount\": {{account1Id}},\n    \"toAccount\":   {{account2Id}},\n    \"amount\":      \"5.00\",\n    \"referenceId\": \"idem-ref-fixed-001\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/transfer", "host": ["{{baseUrl}}"], "path": ["api","transfer"] }
          }
        },
        {
          "name": "POST — 2nd request (same key → same response)",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Response is identical to first request', function () {",
            "    const first = pm.collectionVariables.get('idemResponse1');",
            "    pm.expect(pm.response.text()).to.eql(first);",
            "});"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{fixedIdemKey}}"}],
            "body": { "mode": "raw", "raw": "{\n    \"fromAccount\": {{account1Id}},\n    \"toAccount\":   {{account2Id}},\n    \"amount\":      \"5.00\",\n    \"referenceId\": \"idem-ref-fixed-001\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/transfer", "host": ["{{baseUrl}}"], "path": ["api","transfer"] }
          }
        }
      ]
    },
    {
      "name": "GET Transfer Status",
      "item": [
        {
          "name": "GET /api/transfer/{referenceId} — found",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('success = true', () => pm.expect(pm.response.json().success).to.be.true);",
            "pm.test('data has all fields', function () {",
            "    const d = pm.response.json().data;",
            "    ['referenceId','status','amount','fromAccount','toAccount',",
            "     'fromBeforeBalance','fromAfterBalance','toBeforeBalance','toAfterBalance','createdAt']",
            "    .forEach(k => pm.expect(d).to.have.property(k));",
            "});",
            "pm.test('status = SUCCESS', () => pm.expect(pm.response.json().data.status).to.eql('SUCCESS'));",
            "pm.test('createdAt is ISO 8601', () => pm.expect(pm.response.json().data.createdAt).to.match(/^\\d{4}-\\d{2}-\\d{2}T/));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/transfer/idem-ref-fixed-001", "host": ["{{baseUrl}}"], "path": ["api","transfer","idem-ref-fixed-001"] }
          }
        },
        {
          "name": "GET /api/transfer/{referenceId} — not found (404)",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 404', () => pm.response.to.have.status(404));",
            "pm.test('error field present', () => pm.expect(pm.response.json()).to.have.property('error'));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/transfer/does-not-exist-xyz", "host": ["{{baseUrl}}"], "path": ["api","transfer","does-not-exist-xyz"] }
          }
        }
      ]
    },
    {
      "name": "Error Cases",
      "item": [
        {
          "name": "POST — Insufficient balance (400)",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));",
            "pm.test('error mentions insufficient', () => pm.expect(pm.response.json().error.toLowerCase()).to.include('insufficient'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{$guid}}"}],
            "body": { "mode": "raw", "raw": "{\n    \"fromAccount\": {{account1Id}},\n    \"toAccount\":   {{account2Id}},\n    \"amount\":      \"999999.00\",\n    \"referenceId\": \"insuf-{{$timestamp}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/transfer", "host": ["{{baseUrl}}"], "path": ["api","transfer"] }
          }
        },
        {
          "name": "POST — Same account (400)",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));",
            "pm.test('error field present', () => pm.expect(pm.response.json()).to.have.property('error'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{$guid}}"}],
            "body": { "mode": "raw", "raw": "{\n    \"fromAccount\": {{account1Id}},\n    \"toAccount\":   {{account1Id}},\n    \"amount\":      \"10.00\",\n    \"referenceId\": \"same-{{$timestamp}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/transfer", "host": ["{{baseUrl}}"], "path": ["api","transfer"] }
          }
        },
        {
          "name": "POST — Account not found (404)",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 404', () => pm.response.to.have.status(404));",
            "pm.test('error field present', () => pm.expect(pm.response.json()).to.have.property('error'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{$guid}}"}],
            "body": { "mode": "raw", "raw": "{\n    \"fromAccount\": 99999991,\n    \"toAccount\":   99999992,\n    \"amount\":      \"10.00\",\n    \"referenceId\": \"noact-{{$timestamp}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/transfer", "host": ["{{baseUrl}}"], "path": ["api","transfer"] }
          }
        },
        {
          "name": "POST — Duplicate referenceId different key (400)",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 400 — duplicate referenceId rejected', () => pm.response.to.have.status(400));",
            "pm.test('error mentions referenceId', () => pm.expect(pm.response.json().error.toLowerCase()).to.include('referenceid'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{$guid}}"}],
            "body": { "mode": "raw", "raw": "{\n    \"fromAccount\": {{account1Id}},\n    \"toAccount\":   {{account2Id}},\n    \"amount\":      \"5.00\",\n    \"referenceId\": \"idem-ref-fixed-001\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/transfer", "host": ["{{baseUrl}}"], "path": ["api","transfer"] }
          }
        },
        {
          "name": "POST — Missing Idempotency-Key header (422)",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 422', () => pm.response.to.have.status(422));",
            "pm.test('Validation failed', () => pm.expect(pm.response.json().error).to.eql('Validation failed'));",
            "pm.test('idempotencyKey has error', () => pm.expect(pm.response.json().details).to.have.property('idempotencyKey'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": { "mode": "raw", "raw": "{\n    \"fromAccount\": {{account1Id}},\n    \"toAccount\":   {{account2Id}},\n    \"amount\":      \"10.00\",\n    \"referenceId\": \"no-idem-{{$timestamp}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/transfer", "host": ["{{baseUrl}}"], "path": ["api","transfer"] }
          }
        },
        {
          "name": "POST — Missing body fields (400)",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));",
            "pm.test('error mentions missing fields', () => pm.expect(pm.response.json().error).to.include('Missing required fields'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{$guid}}"}],
            "body": { "mode": "raw", "raw": "{\n    \"amount\": \"10.00\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/transfer", "host": ["{{baseUrl}}"], "path": ["api","transfer"] }
          }
        },
        {
          "name": "POST — Invalid JSON (400)",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));",
            "pm.test('error field present', () => pm.expect(pm.response.json()).to.have.property('error'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{$guid}}"}],
            "body": { "mode": "raw", "raw": "{not valid json at all" },
            "url": { "raw": "{{baseUrl}}/api/transfer", "host": ["{{baseUrl}}"], "path": ["api","transfer"] }
          }
        },
        {
          "name": "POST — Negative amount (422)",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 422', () => pm.response.to.have.status(422));",
            "pm.test('amount has validation error', () => pm.expect(pm.response.json().details).to.have.property('amount'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{$guid}}"}],
            "body": { "mode": "raw", "raw": "{\n    \"fromAccount\": {{account1Id}},\n    \"toAccount\":   {{account2Id}},\n    \"amount\":      \"-50.00\",\n    \"referenceId\": \"neg-{{$timestamp}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/transfer", "host": ["{{baseUrl}}"], "path": ["api","transfer"] }
          }
        },
        {
          "name": "POST — Too many decimals (422)",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 422', () => pm.response.to.have.status(422));",
            "pm.test('amount has validation error', () => pm.expect(pm.response.json().details).to.have.property('amount'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"},{"key":"Idempotency-Key","value":"{{$guid}}"}],
            "body": { "mode": "raw", "raw": "{\n    \"fromAccount\": {{account1Id}},\n    \"toAccount\":   {{account2Id}},\n    \"amount\":      \"10.999\",\n    \"referenceId\": \"dec-{{$timestamp}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/transfer", "host": ["{{baseUrl}}"], "path": ["api","transfer"] }
          }
        }
      ]
    }
  ]
}
